{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/buttons/**",
              "components/cards/**",
              "components/footer/**",
              "components/forms/**",
              "components/icons/**",
              "components/misc/**",
              "components/navigation/**",
              "components/sections/**",
              "ui_kits/marketing-site/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Montserrat|Fredoka))/i]",
        "message": "Font not provided by the design system. Available: Montserrat, Fredoka."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|href|onClick|disabled|showIcon|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, href, onClick, disabled, showIcon."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|slider-cta)$/]",
        "message": "<Button> variant must be one of 'primary' | 'slider-cta'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FormInput'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|type|required|placeholder|key|ref|className|style|children)$/]",
        "message": "<FormInput> doesn't accept that prop. Declared props: label, type, required, placeholder."
      },
      {
        "selector": "JSXOpeningElement[name.name='FormInput'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:text|email|tel|textarea)$/]",
        "message": "<FormInput> type must be one of 'text' | 'email' | 'tel' | 'textarea'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FormSubmitButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|disabled|key|ref|className|style|children)$/]",
        "message": "<FormSubmitButton> doesn't accept that prop. Declared props: label, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|color|strokeWidth|style|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, color, strokeWidth, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute[name.name='name'] > Literal[value!=/^(?:chevron-right|check|x|menu|mail|phone|map-pin|message-circle|search|users|target|bar-chart|trending-up|arrow-up-right)$/]",
        "message": "<Icon> name must be one of 'chevron-right' | 'check' | 'x' | 'menu' | 'mail' | 'phone' | 'map-pin' | 'message-circle' | 'search' | 'users' | 'target' | 'bar-chart' | 'trending-up' | 'arrow-up-right'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MethodologyIconBlock'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|title|description|key|ref|className|style|children)$/]",
        "message": "<MethodologyIconBlock> doesn't accept that prop. Declared props: icon, title, description."
      },
      {
        "selector": "JSXOpeningElement[name.name='MethodologyIconBlock'] > JSXAttribute[name.name='icon'] > Literal[value!=/^(?:target|trending-up|bar-chart|search|users|check)$/]",
        "message": "<MethodologyIconBlock> icon must be one of 'target' | 'trending-up' | 'bar-chart' | 'search' | 'users' | 'check'."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|items|key|ref|className|style|children)$/]",
        "message": "<NavBar> doesn't accept that prop. Declared props: variant, items."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavBar'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:transparent|solid)$/]",
        "message": "<NavBar> variant must be one of 'transparent' | 'solid'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PortraitImage'] > JSXAttribute > JSXIdentifier[name!=/^(?:image|size|key|ref|className|style|children)$/]",
        "message": "<PortraitImage> doesn't accept that prop. Declared props: image, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionCTAPhoto'] > JSXAttribute > JSXIdentifier[name!=/^(?:image|eyebrow|title|body|buttonLabel|buttonHref|height|navSlot|key|ref|className|style|children)$/]",
        "message": "<SectionCTAPhoto> doesn't accept that prop. Declared props: image, eyebrow, title, body, buttonLabel, buttonHref, height, navSlot."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionSurfaceLight'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|key|ref|className|style|children)$/]",
        "message": "<SectionSurfaceLight> doesn't accept that prop. Declared props: children."
      },
      {
        "selector": "JSXOpeningElement[name.name='ServiceTile'] > JSXAttribute > JSXIdentifier[name!=/^(?:image|title|href|key|ref|className|style|children)$/]",
        "message": "<ServiceTile> doesn't accept that prop. Declared props: image, title, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='SocialIcon'] > JSXAttribute > JSXIdentifier[name!=/^(?:network|size|color|style|key|ref|className|style|children)$/]",
        "message": "<SocialIcon> doesn't accept that prop. Declared props: network, size, color, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SocialIcon'] > JSXAttribute[name.name='network'] > Literal[value!=/^(?:facebook|instagram|linkedin|tiktok)$/]",
        "message": "<SocialIcon> network must be one of 'facebook' | 'instagram' | 'linkedin' | 'tiktok'."
      },
      {
        "selector": "JSXOpeningElement[name.name='WhatsAppButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:tooltip|key|ref|className|style|children)$/]",
        "message": "<WhatsAppButton> doesn't accept that prop. Declared props: tooltip."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
